{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:client": "vite dev --host 127.0.0.1 --port 5012 --strictPort",
    "dev": "npm run local:start",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "typecheck": "tsc",
    "test": "vitest run",
    "qa": "npm run typecheck && npm run build",
    "db:push": "drizzle-kit push",
    "db:push:local": "tsx scripts/dev/withLocalBetterAuthEnv.ts npx tsx scripts/dev/runLocalDbPush.ts",
    "seed:dev-users": "NODE_ENV=development tsx scripts/seed-dev-users.ts",
    "seed:dev-users:local": "tsx scripts/dev/withLocalBetterAuthEnv.ts npm run seed:dev-users -- --confirm",
    "verify:seed-auth": "tsx scripts/db/verifySeedAuthFixtures.ts",
    "env:test:hydrate": "tsx scripts/dev/hydrateTestEnvFrom1Password.ts",
    "env:test:hydrate:force": "tsx scripts/dev/hydrateTestEnvFrom1Password.ts --force",
    "with:test-env": "tsx scripts/dev/withLocalBetterAuthEnv.ts",
    "with:local-auth-env": "tsx scripts/dev/withLocalBetterAuthEnv.ts",
    "doctor:local": "tsx scripts/dev/withLocalBetterAuthEnv.ts npx tsx scripts/doctor.ts",
    "verify:seed-auth:local": "tsx scripts/dev/withLocalBetterAuthEnv.ts npm run verify:seed-auth",
    "check:local": "npm run db:push:local && npm run seed:dev-users:local && npm run verify:seed-auth:local && npm run typecheck && npm run doctor:local && npm run with:test-env -- npx tsx scripts/db/verifySchema.ts && npm run test:local",
    "ci:check": "npm run typecheck && npx tsx scripts/doctor.ts && npx tsx scripts/db/verifySchema.ts && npm run test",
    "mailgun:live:check": "npx tsx scripts/mailgun-live-check.ts",
    "email:preview:audit": "npx tsx scripts/email-preview-audit.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:full": "npx playwright test",
    "test:e2e:critical": "npx playwright test e2e/smoke.spec.ts e2e/admin-auth.spec.ts e2e/customer-auth.spec.ts e2e/affiliate-portal.spec.ts e2e/auth-verification.spec.ts e2e/shop.spec.ts e2e/cart-checkout.spec.ts e2e/admin-products.spec.ts e2e/customer-password-reset.spec.ts --project=chromium",
    "test:local": "npm run test:unit:local && npm run test:cms-generator && npm run test:e2e:local",
    "test:unit:local": "tsx scripts/dev/withLocalBetterAuthEnv.ts vitest run",
    "test:cms-generator": "tsx client/src/admin/cms/generator/assembleLandingPage.test.ts",
    "test:e2e:local": "tsx scripts/dev/withLocalBetterAuthEnv.ts npx playwright test",
    "test:e2e:full:local": "tsx scripts/dev/withLocalBetterAuthEnv.ts npx playwright test",
    "test:e2e:critical:local-auth": "tsx scripts/dev/withLocalBetterAuthEnv.ts npx playwright test e2e/smoke.spec.ts e2e/admin-auth.spec.ts e2e/customer-auth.spec.ts e2e/affiliate-portal.spec.ts e2e/auth-verification.spec.ts e2e/shop.spec.ts e2e/cart-checkout.spec.ts e2e/admin-products.spec.ts e2e/customer-password-reset.spec.ts --project=chromium",
    "test:e2e:local-auth": "tsx scripts/dev/withLocalBetterAuthEnv.ts npx playwright test",
    "test:unit": "vitest run",
    "postinstall": "tsx scripts/ensure-assets.ts",
    "dev:local": "npm run local:start",
    "dev:client:local": "vite dev --host 127.0.0.1 --port 5012 --strictPort",
    "setup:local": "tsx scripts/ensure-assets.ts",
    "local:urls": "printf 'App: http://powerplunge.localhost\\nDirect: http://localhost:5011\\nStart: npm run local:start\\nCaddy: /opt/homebrew/etc/Caddyfile\\n'",
    "local:start": "BETTER_AUTH_BASE_URL=http://powerplunge.localhost PUBLIC_SITE_URL=http://powerplunge.localhost BASE_URL=http://powerplunge.localhost APP_URL=http://powerplunge.localhost CORS_ALLOWED_ORIGINS=http://powerplunge.localhost PORT=5011 NODE_ENV=development tsx server/index.ts",
    "dev:all": "concurrently --names server,client \"npm run local:start\" \"npm run dev:client:local\""
  },
