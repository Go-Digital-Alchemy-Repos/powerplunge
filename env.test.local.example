# Example template for local automated test env hydration.
# Keep real 1Password item references in ignored `.env.test.local.template`.
# Run `npm run env:test:hydrate` to write ignored `.env.test.local`.

DATABASE_URL=op://<vault>/<local-test-database-url-item>/<field>
SESSION_SECRET=op://<vault>/<session-secret-item>/<field>
BETTER_AUTH_SECRET=op://<vault>/<better-auth-secret-item>/<field>
APP_SECRETS_ENCRYPTION_KEY=op://<vault>/<app-secrets-encryption-key-item>/<field>
IP_HASH_SALT=op://<vault>/<ip-hash-salt-item>/<field>

LOCAL_TEST_DATABASE=true
LOCAL_TEST_DATABASE_HOST=<expected-local-test-database-host>
NODE_ENV=development
PORT=5001
E2E_PORT=5001
E2E_BASE_URL=http://localhost:5001
BETTER_AUTH_BASE_URL=http://localhost:5001
PUBLIC_SITE_URL=http://localhost:5001
E2E_TEST_MODE=true
E2E_EMAIL_MODE=outbox
SEED_TEST_PASSWORD=testpass123

MAILGUN_API_KEY=
MAILGUN_DOMAIN=
STRIPE_MODE=test
STRIPE_SECRET_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_CONNECT_WEBHOOK_SECRET=
